{
  "@context": "http://www.w3.org/ns/csvw",
  "url": "transactions.csv",
  "tableSchema": {
    "columns": [
      {
        "name": "transactionId",
        "titles": "Transaction ID",
        "datatype": "string",
        "required": true,
        "minLength": 5,
        "maxLength": 20
      },
      {
        "name": "date",
        "titles": "Date",
        "datatype": "date",
        "required": true
      },
      {
        "name": "amount",
        "titles": "Amount",
        "datatype": "number",
        "required": true,
        "minimum": 0
      },
      {
        "name": "currency",
        "titles": "Currency",
        "datatype": "string",
        "required": true,
        "format": "^[A-Z]{3}$"
      },
      {
        "name": "status",
        "titles": "Status",
        "datatype": "string",
        "required": true,
        "constraints": {
          "enum": ["PENDING", "COMPLETED", "FAILED", "CANCELLED"]
        }
      }
    ],
    "primaryKey": "transactionId"
  }
}